@startuml the_deep
skinparam classAttributeIconSize 0
skinparam Nodesep 50
skinparam Ranksep 50
skinparam Linetype ortho
skinparam shadowing false
skinparam BackgroundColor transparent
skinparam package<<core>> {
    BackgroundColor HoneyDew
    BorderColor DarkSeaGreen
}
skinparam package<<states>> {
    BackgroundColor PaleGreen
    BorderColor DarkGreen
}
skinparam package<<things>> {
    BackgroundColor LightYellow
    BorderColor Yellow
}
skinparam package<<UI>> {
    BackgroundColor LightCoral
    BorderColor Coral
}
skinparam package<<world>> {
    BackgroundColor LightBlue
    BorderColor Blue
}
skinparam package<<utilities>> {
    BackgroundColor AliceBlue
    BorderColor SteelBlue
}

top to bottom direction

' === Core Runtime ===
package core <<core>> {
class GameManager {
    - is_running: bool
    - screen: pygame.Surface
    - clock: pygame.time.Clock
    - fps: int
    - states: dict[str, BaseState]
    - current_state: BaseState
    + get_whats_going_on(): void
    + update(dt: float): void
    + transition_states(): void
    + run(): void
}
}

package states <<states>> {
    abstract class BaseState {
        - screen_size: tuple[int, int]
        - is_done: tuple[bool, None|str]
        - is_quitting: bool
        + {abstract} enter(data: dict = {}): void
        + {abstract} handle_event(event: Event): void
        + {abstract} update(dt: float): void
        + {abstract} draw(surface: Surface): void
        + {abstract} exit(): void
    }

    class StartScreen {
        - buttons: list[Button]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(surface: Surface): void
        + exit(): void
        + quit_game(): void
    }

    class UnderwaterState {
        - player: Player
        - camera: Camera
        - map: TileMap
        - button: Button
        - creatures: list[Creature]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(surface: Surface): void
        + exit(): void
        + spawn_creatures(): void
        + check_return_point(): bool
        + update_depth(): void
        + _trigger_game_over(): void
    }

    class HomebaseState {
        - player: Player
        - map: TileMap
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(surface: Surface): void
        + exit(): void
    }

    class GameOverState {
        - buttons: list[Button]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(surface: Surface): void
        + exit(): void
    }
}

package things <<things>> {
    abstract class Thing {
        - image: pygame.Surface
        - pos: pygame.math.Vector2
        - rect: pygame.Rect
        + update(dt: float): void
        + draw(surface: Surface): void
    }

    abstract class MovingThing {
        - thrust: float
        - velocity: pygame.math.Vector2
        - movement_axis: pygame.math.Vector2
        - is_sprinting: bool
        - sprint_multiplier: float
        + handle_inputs(keys): void
        + update(dt: float): void
    }
    

    package moving_things <<things>> {
        class Player {
            - health: int
            - max_health: int
            - oxygen: float
            - max_oxygen: float
            - oxygen_depletion_rate: float
            - depth: float
            - max_depth_limit: float
            - buffer_inventory: List[Item]
            - buffer_inventory_capacity: int
            - holdables: List[Holdable]
            - active_holdable: Holdable
            + update(dt: float): void
            + draw(surface: Surface): void
            + update_oxygen(): void
            + update_depth_damage(): void
            + heal(): void
            + interact(): void
            + revert(): void
        }

        abstract class Creature {
            - health: int
            - max_health: int
            + think(dt: float, player_pos: Vec2): Vec2
            + update(dt: float): void
            + draw(surface: Surface): void
            + get_damaged(amount: int): void
            + is_dead(): bool
        }

        class PassiveCreature {
            - fear_radius: float
            + think(dt: float, player_pos: Vec2): Vec2
        }

        class AggressiveCreature {
            - chase_radius: float
            + think(dt: float, player_pos: Vec2): Vec2
        }
    }

    package items <<things>> {
        class Item {
            + interact(): void
        }

        abstract class Holdable {
            - range: float
            - cooldown_s: float
            - is_available: bool
            + {abstract} shoot(pos: tuple[int, int]): void
        }

        class Weapon {
            - damage: int
            - ammo: int
            + shoot(pos: tuple[int,int]): void
        }

        class Harpoon {
            - projectile_speed: float
            + shoot(pos: tuple[int,int]): void
        }

        class ResearchGun {
            - scan_rate: float
            + shoot(pos: tuple[int,int]): void
        }
    }
}

package world <<world>> {
    class TileMap {
        - path: Path
        - visual_layer: pygame.Surface
        - collision_layer: List[List[int]]
        - tile_size: tuple[int, int]
        - map_size: tuple[int, int]
        + parse_from_path(path: Path): void
        + draw(surface: Surface, camera_rect: Rect): void
        + is_tile_solid(x: int, y: int): bool
        + get_tile_at_position(x: float, y: float): tuple
        + get_closest_interactable(x: float, y: float, max_distance: int): Interactable
    }

    class Camera {
        - offset: pygame.math.Vector2
        - world_size: pygame.Rect
        - map_boundaries: pygame.Rect
        + update(dt: float, target_rect: pygame.Rect): void
        + draw(world_surface: Surface, screen: Surface): void
    }

    abstract class Interactable {
        - rect: pygame.Rect
        - prompt_text: str
        + {abstract} interact(): void
        + draw_prompt(surface: Surface): void
    }

    class Exit {
        - on_interact: callable
        + interact(): void
    }

    class Upgrades {
        + interact(): void
    }

    class Research {
        + interact(): void
    }
}

package utils <<utilities>> {
    class PhysicsService {
        + resolve_map_collision_on_x_axis(entity: MovingThing, tiles: list[Rect]): void
        + resolve_map_collision_on_y_axis(entity: MovingThing, tiles: list[Rect]): void
        + resolve_player_creature_collisions(player: Player, creatures: list[Creature], tiles: list[Rect]): list[Item]
    }

    class DataManager {
        - save_data: dict
        + load(path: Path): dict
        + save(path: Path): void
        + get(key: str, default=None): Any
        + set(key: str, value: Any): void
    }
}

package ui <<UI>> {

abstract class BaseMenu {
    - is_open: bool
    + {abstract} open(): void
    + {abstract} close(): void
    + {abstract} handle_event(event: Event): void
    + {abstract} update(dt: float): void
    + {abstract} draw(surface: Surface): void
}

class HUD {
    - font: pygame.font.Font
    - debug_mode: bool
    + draw(screen: Surface, player: Player): void
    + draw_health(screen: Surface, health: int): void
    + draw_oxygen(screen: Surface, oxygen: float): void
    + draw_depth(screen: Surface, depth: float): void
    + draw_debug_info(screen: Surface, fps: int, coords: tuple): void
}

class Button {
    - color: tuple[int, int, int]
    - hover_color: tuple[int, int, int]
    - size: tuple[int, int]
    - func: callable
    - surface: pygame.Surface
    - rect: pygame.Rect
    - font: pygame.font.Font
    - txt: str
    - font_color: tuple[int, int, int]
    - txt_surf: pygame.Surface
    - txt_rect: pygame.Rect
    - curcolor: tuple[int, int, int]
    + draw(screen: Surface): void
    + mouseover(): void
    + call_back(*args): Any
}

}

' === Relationships ===

GameManager o-down- "*" BaseState : registry

BaseState <|-- StartScreen
BaseState <|-- UnderwaterState
BaseState <|-- HomebaseState
BaseState <|-- GameOverState

Thing <|-- MovingThing
MovingThing <|-- Player
MovingThing <|-- Creature
Thing <|-- Item

Creature <|-- PassiveCreature
Creature <|-- AggressiveCreature

Thing <|-- Holdable
Holdable <|-- Weapon
Holdable <|-- Harpoon
Holdable <|-- ResearchGun

Interactable <|-- Exit
Interactable <|-- Upgrades
Interactable <|-- Research

' --- State Relations ---
UnderwaterState o-- Player
HomebaseState o-- Player
StartScreen o-- "*" Button
UnderwaterState o-- Button
GameOverState o-- "*" Button
Player o-- "*" Holdable

UnderwaterState o-- "*" Creature
UnderwaterState o-- TileMap
UnderwaterState o-- Camera
UnderwaterState ..> PhysicsService
UnderwaterState o-- "0..1" Interactable : closest
HomebaseState o-- TileMap
HomebaseState o-- "0..1" Interactable : closest
HomebaseState ..> BaseMenu
HomebaseState ..> DataManager

PhysicsService ..> TileMap : checks
PhysicsService ..> MovingThing : checks
TileMap o-- "*" Interactable

core -[hidden]down-> states
states -[hidden]down-> things
states -[hidden]down-> world
states -[hidden]down-> utils
states -[hidden]down-> ui

things -[hidden]left-> world
utils -[hidden]right-> world
ui -[hidden]right-> world

Button -[hidden]up-> HUD
@enduml