@startuml the_deep
skinparam classAttributeIconSize 0
skinparam Nodesep 50
skinparam Ranksep 50
skinparam Linetype ortho
skinparam shadowing false
skinparam BackgroundColor transparent
skinparam package<<core>> {
    BackgroundColor HoneyDew
    BorderColor DarkSeaGreen
}
skinparam package<<states>> {
    BackgroundColor PaleGreen
    BorderColor DarkGreen
}
skinparam package<<things>> {
    BackgroundColor LightYellow
    BorderColor Yellow
}
skinparam package<<UI>> {
    BackgroundColor LightCoral
    BorderColor Coral
}
skinparam package<<world>> {
    BackgroundColor LightBlue
    BorderColor Blue
}
skinparam package<<utilities>> {
    BackgroundColor AliceBlue
    BorderColor SteelBlue
}

top to bottom direction

' === Core Runtime ===
package core <<core>> {
class GameManager {
    - is_running: bool
    - is_debug_on: bool
    - screen: pygame.Surface
    - clock: pygame.time.Clock
    - fps: int
    - states: dict[str, BaseState]
    - current_state: BaseState
    + get_whats_going_on(): void
    + update(dt: float): void
    + transition_states(): void
    + run(): void
}
}

package states <<states>> {
    abstract class BaseState {
        - is_done: tuple[bool, None|str]
        - is_quitting: bool
        + {abstract} enter(data: dict = {}): void
        + {abstract} handle_event(event: Event): void
        + {abstract} update(dt: float): void
        + {abstract} draw(screen: Surface, is_debug_on: bool): void
        + {abstract} exit(): void
    }

    class StartScreen {
        - buttons: list[Button]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(screen: Surface, is_debug_on: bool): void
        + exit(): void
        + quit_game(): void
    }

    class UnderwaterState {
        - player: Player
        - camera: Camera
        - tile_map: TileMap
        - world_surface: Surface
        - world_rect: Rect
        - oxygen_tanks: list[OxygenTank]
        - closest_interactable: Interactable
        - research_database: ResearchDatabase
        - held_inventory: HeldInventory
        - button: Button
        - creatures: list[Creature]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(screen: Surface, is_debug_on: bool): void
        + exit(): void
        + _spawn_creatures(): void
        + _spawn_oxygen_tanks(): void
        + _update_shootables(dt: float): void
        + _trigger_game_over(): void
    }

    class HomebaseState {
        - player: Player
        - tile_map: TileMap
        - world_surface: Surface
        - world_rect: Rect
        - camera: Camera
        - closest_interactable: Interactable
        - research_database: ResearchDatabase
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(screen: Surface, is_debug_on: bool): void
        + exit(): void
    }

    class GameOverState {
        - buttons: list[Button]
        + enter(data: dict = {}): void
        + handle_event(event: Event): void
        + update(dt: float): void
        + draw(screen: Surface, is_debug_on: bool): void
        + exit(): void
        + quit_game(): void
    }
}

package things <<things>> {
    abstract class Thing {
        - image: pygame.Surface
        - pos: pygame.math.Vector2
        - rect: pygame.Rect
        + update(dt: float, bound_rect: pygame.Rect): void
        + draw(surface: Surface): void
    }

    abstract class MovingThing {
        - thrust: float
        - velocity: pygame.math.Vector2
        - input_direction: pygame.math.Vector2
        - mass: float
        - damage: int
        + update(dt: float, bound_rect: pygame.Rect, area_tiles: list[Rect]): void
    }

    package moving_things {
        class Player {
            - health: int
            - max_health: int
            - oxygen: float
            - max_oxygen: float
            - oxygen_depletion_rate: float
            - inventory: dict[str, int]
            - current_holdable: Holdable
            - _left_click_pressed: bool
            + update(dt: float, bound_rect: pygame.Rect, area_tiles: list[Rect]): void
            + draw(surface: Surface): void
            + handle_event(event: Event): void
            + set_holdable(holdable: Holdable | None): void
            + update_animation_underwater(dt: float): void
            + update_animation_homebase(dt: float): void
            + revert(): void
        }

        abstract class Creature {
            - health: int
            - max_health: int
            - flash_timer: float
            - flash_duration: float
            - death_anim: Animation
            - is_dying: bool
            + think(dt: float, player_pos: Vec2): Vec2
            + update(dt: float, bound_rect: pygame.Rect, area_tiles: list[Rect], player_pos: Vec2): void
            + draw(surface: Surface): void
            + get_damaged(amount: int): void
            + is_dead(): bool
        }

        class PassiveCreature {
            - fear_radius: float
            + think(dt: float, player_pos: Vec2): Vec2
        }

        class AggressiveCreature {
            - chase_radius: float
            + think(dt: float, player_pos: Vec2): Vec2
        }

        class Projectile {
            - max_range: float
            - spawn_pos: pygame.math.Vector2
            - is_destroyed: bool
            + update(dt: float, bound_rect: pygame.Rect, area_tiles: list[Rect]): void
            + destroy(): void
        }

        class Ray {
            - origin: pygame.math.Vector2
            - end_pos: pygame.math.Vector2
            - range: float
            - beam_color: tuple[int, int, int]
            + update(origin, target_pos): void
            + get_creatures_in_beam(creatures: list): list
            + draw(surface: Surface): void
        }
    }

    package items {
        class Item {
            + interact(): void
            + draw(screen: Surface): void
        }

        abstract class Holdable {
            - continuous: bool
            - is_available: bool
            - name: str
            - description: str
            - color: tuple[int, int, int]
            - image_path: Path | None
            - range: float
            - cooldown_s: float
            - shoot_recoil: int
            - shootables: list
            - aim_direction: pygame.math.Vector2
            - player_center: pygame.math.Vector2
            + {abstract} shoot(pos: tuple[int, int]): void
            + update(dt: float, bound_rect: pygame.Rect, player_pos): void
            + update_shootables(dt: float, creatures: list, world_rect=None, get_tiles=None): tuple[list, list]
            + draw(surface: Surface): void
        }

        class Weapon {
            - damage: int
            - ammo: int
            - shot_dt: float
            - thrust: float
            + shoot(pos: tuple[int, int]): bool
            + update_shootables(dt: float, creatures: list, world_rect=None, get_tiles=None): tuple[list, list]
            + draw_things_on_screen(surface): void
        }

        class Harpoon {
            - projectile_speed: float
            + shoot(pos: tuple[int, int]): void
        }

        class ResearchGun {
            - scan_rate: float
            - research_database: ResearchDatabase
            - scan_timers: dict
            - beam_creatures: set
            + shoot(pos: tuple[int, int]): bool
            + update_shootables(dt: float, creatures: list, world_rect=None, get_tiles=None): tuple[list, list]
            + draw_things_on_screen(surface): void
        }
    }
}

package world <<world>> {
    class TileMap {
        - visual_surface: pygame.Surface
        - tile_size: tuple[int, int]
        - map_size: tuple[int, int]
        - tile_layers: dict[str, Any]
        - mid_layer: Any
        - interactables: list[Interactable]
        - tilesets: list[tuple[int, pygame.Surface | dict, int]]
        + parse_from_path(path: Path): void
        + draw(surface: Surface, camera_rect: Rect): void
        + is_tile_solid(x: int, y: int): bool
        + get_tiles_at_area(x: float, y: float, size: tuple[int, int]): list[Rect]
        + get_tile_at_position(x: float, y: float): tuple
        + get_closest_interactable(x: float, y: float, max_distance: int): Interactable
    }

    class Camera {
        - pos: pygame.math.Vector2
        - target: pygame.math.Vector2
        - size: tuple[int, int]
        - map_rect: pygame.Rect
        - rect: pygame.Rect
        - zoom: float
        - camera_surface: pygame.Surface
        + update(dt: float, target_rect: pygame.Rect): void
        + draw(world_surface: Surface, screen: Surface): void
    }

    abstract class Interactable {
        - rect: pygame.Rect
        - prompt_text: str
        + {abstract} interact(): void
        + draw_prompt(surface: Surface): void
    }

    class Exit {
        - on_interact: callable
        + interact(): void
    }

    class Upgrades {
        + interact(): void
    }

    class Research {
        + interact(): void
    }

    class OxygenTank {
        - oxygen_refill: float
        + interact(): void
        + draw(surface: Surface): void
    }
}

package utils <<utilities>> {
    class PhysicsService {
        + resolve_map_collision_on_x_axis(entity: MovingThing, tiles: list[Rect]): void
        + resolve_map_collision_on_y_axis(entity: MovingThing, tiles: list[Rect]): void
        + resolve_player_creature_collisions(player: Player, creatures: list[Creature], tiles: list[Rect]): list[Item]
        + resolve_player_item_pickups(player: Player, items: list[Item], dt: float): list[Item]
        + resolve_projectile_creature_collisions(projectiles: list[Projectile], creatures: list[Creature]): tuple[list, list]
    }

    class Animation {
        - frames: list
        - fps: int
        - loop: bool
        - timer: float
        - index: int
        - finished: bool
        + get_image(): Surface
        + update(dt: float): void
        + reset(): void
    }

    class ResearchDatabase {
        - research_data: dict[str, dict[str, float]]
        + get_scan_progress(creature_species: str, is_alive: bool): float
        + update_scan_progress(creature_species: str, is_alive: bool, progress: float): void
        + get_total_species_progress(creature_species: str): float
    }

    class DataManager {
        - save_data: dict
        + load(path: Path): dict
        + save(path: Path): void
        + get(key: str, default=None): Any
        + set(key: str, value: Any): void
    }
}

package ui <<UI>> {
    class HeldInventory {
        - slot_size: tuple[int, int]
        - padding: int
        - selected_index: int
        - holdables: list[Holdable]
        - slot_count: int
        - pos: tuple[int, int]
        - label_font: pygame.font.Font
        - _scaled_icons: dict[int, pygame.Surface]
        + remove_holdable(index): void
        + append_holdables(new_holdables: list[Holdable]): void
        + select(index: int): void
        + handle_event(event: Event): void
        + selected_holdable(): Holdable
        + draw(screen: Surface): void
    }

    class Button {
        - color: tuple[int, int, int]
        - hover_color: tuple[int, int, int]
        - size: tuple[int, int]
        - func: callable
        - surface: pygame.Surface
        - rect: pygame.Rect
        - font: pygame.font.Font
        - txt: str
        - font_color: tuple[int, int, int]
        - txt_surf: pygame.Surface
        - txt_rect: pygame.Rect
        - curcolor: tuple[int, int, int]
        + draw(screen: Surface): void
        + check_mouseover(mouse_pos: tuple[int, int]): void
        + call_back(*args): Any
    }
}

' === Relationships ===

GameManager o-down- "*" BaseState : registry

BaseState <|-- StartScreen
BaseState <|-- UnderwaterState
BaseState <|-- HomebaseState
BaseState <|-- GameOverState

Thing <|-- MovingThing
MovingThing <|-- Player
MovingThing <|-- Creature
MovingThing <|-- Projectile

Creature <|-- PassiveCreature
Creature <|-- AggressiveCreature

Thing <|-- Holdable
Holdable <|-- Weapon
Holdable <|-- Harpoon
Holdable <|-- ResearchGun

Interactable <|-- Exit
Interactable <|-- Upgrades
Interactable <|-- Research
Interactable <|-- OxygenTank

' --- State Relations ---
UnderwaterState o-- Player
HomebaseState o-- Player
StartScreen o-- "*" Button
UnderwaterState o-- Button
GameOverState o-- "*" Button
UnderwaterState o-- HeldInventory
HeldInventory o-- "*" Holdable
Player o-- "0..1" Holdable : current_holdable

UnderwaterState o-- "*" Creature
UnderwaterState o-- TileMap
UnderwaterState o-- Camera
UnderwaterState o-- "*" OxygenTank
UnderwaterState o-- ResearchDatabase
UnderwaterState ..> PhysicsService
UnderwaterState o-- "0..1" Interactable : closest
HomebaseState o-- TileMap
HomebaseState o-- "0..1" Interactable : closest
HomebaseState o-- Camera
HomebaseState o-- ResearchDatabase
HomebaseState ..> DataManager

Weapon ..> Projectile
ResearchGun ..> Ray
PhysicsService ..> TileMap : checks
PhysicsService ..> MovingThing : checks
PhysicsService ..> Projectile : checks
TileMap o-- "*" Interactable

core -[hidden]down-> states
states -[hidden]down-> things
states -[hidden]down-> world
states -[hidden]down-> utils
states -[hidden]down-> ui

things -[hidden]left-> world
utils -[hidden]right-> world
ui -[hidden]right-> world
@enduml